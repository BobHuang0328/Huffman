#include "huff.h"
#include <stdlib.h>
void print_help(void) {
    printf("====== Huffman File Compressor ======\n");
    printf("Usage:\n");
    printf("  Compress:   huff -c <files...> -o <output.huff>\n");
    printf("  Decompress: huff -x <input.huff> -d <output_dir>\n");
    printf("  Help:       huff -h\n");
    printf("\nOptions:\n");
    printf("  -c  Compress files (supports wildcards * and ?)\n");
    printf("  -x  Decompress files\n");
    printf("  -o  Output compressed file name\n");
    printf("  -d  Decompression output directory\n");
    printf("  -h  Show help\n");
    printf("\nExamples:\n");
    printf("  huff -c *.txt -o backup.huff\n");
    printf("  huff -c data\\*.bin -o data.huff\n");
    printf("  huff -x backup.huff -d restored\n");
}
int parse_args(int argc, char* argv[], int* mode,
               char* output_path, char* input_path, char* output_dir,
               FileHeader* file_list, int* file_count) {
    int i;
    char* s;
    *mode = 0;
    *file_count = 0;
    output_path[0] = '\0';
    input_path[0] = '\0';
    output_dir[0] = '\0';
    for (i = 1; i < argc; i++) {
        if (strcmp(argv[i], "-h") == 0) {
            print_help();
            system("pause");
            exit(0);
        } else if (strcmp(argv[i], "-c") == 0) {
            *mode = 1;
        } else if (strcmp(argv[i], "-x") == 0) {
            *mode = 2;
            if (i + 1 < argc) {
                strncpy(input_path, argv[++i], PATH_LEN - 1);
                input_path[PATH_LEN - 1] = '\0';
            }
        } else if (strcmp(argv[i], "-o") == 0) {
            if (i + 1 < argc) {
                strncpy(output_path, argv[++i], PATH_LEN - 1);
                output_path[PATH_LEN - 1] = '\0';
            }
        } else if (strcmp(argv[i], "-d") == 0) {
            if (i + 1 < argc) {
                strncpy(output_dir, argv[++i], PATH_LEN - 1);
                output_dir[PATH_LEN - 1] = '\0';
            }
        } else if (*mode == 1) {
            if (strchr(argv[i], '*') || strchr(argv[i], '?')) {
                char dir[PATH_LEN] = ".";
                char pat[PATH_LEN];
                char* last_sep;
                strncpy(pat, argv[i], PATH_LEN - 1);
                pat[PATH_LEN - 1] = '\0';
                last_sep = strrchr(pat, '\\');
                s = strrchr(pat, '/');
                if (s != NULL && last_sep == NULL) last_sep = s;
                if (s != NULL && last_sep != NULL && s > last_sep) last_sep = s;
                if (last_sep) {
                    *last_sep = '\0';
                    strncpy(dir, pat, PATH_LEN - 1);
                    dir[PATH_LEN - 1] = '\0';
                    strncpy(pat, last_sep + 1, PATH_LEN - 1);
                    pat[PATH_LEN - 1] = '\0';
                }
                scan_directory(dir, pat, file_list, file_count);
            } else {
                FILE* f = fopen(argv[i], "rb");
                if (f) {
                    fseek(f, 0, SEEK_END);
                    long sz = ftell(f);
                    fclose(f);
                    if (*file_count >= MAX_FILES) {
                        printf("Error: too many files (max %d)\n", MAX_FILES);
                        system("pause");
                        return 1;
                    }
                    strncpy(file_list[*file_count].name, argv[i], PATH_LEN - 1);
                    file_list[*file_count].name[PATH_LEN - 1] = '\0';
                    file_list[*file_count].file_size = sz;
                    file_list[*file_count].is_dir = 0;
                    (*file_count)++;
                } else {
                    printf("Warning: file not found, skipping: %s\n", argv[i]);
                }
            }
        }
    }
    if (*mode == 0) {
        printf("Error: specify -c (compress) or -x (decompress)\n");
        print_help();
        system("pause");
        return 1;
    }
    if (*mode == 1 && (*file_count == 0 || strlen(output_path) == 0)) {
        printf("Error: compress mode needs input files and -o <output.huff>\n");
        print_help();
        system("pause");
        return 1;
    }
    if (*mode == 2 && (strlen(input_path) == 0 || strlen(output_dir) == 0)) {
        printf("Error: decompress mode needs -x <input.huff> and -d <output_dir>\n");
        print_help();
        system("pause");
        return 1;
    }
    return 0;
}
long calc_total_size(FileHeader* file_list, int file_count) {
    long total = 0;
    int i;
    for (i = 0; i < file_count; i++) {
        total += file_list[i].file_size;
    }
    return total;
}
int main(int argc, char* argv[]) {
    int mode;
    char output_path[PATH_LEN];
    char input_path[PATH_LEN];
    char output_dir[PATH_LEN];
    FileHeader file_list[MAX_FILES];
    int file_count;
    if (parse_args(argc, argv, &mode, output_path, input_path, output_dir,
                   file_list, &file_count) != 0) {
        return 1;
    }
    if (mode == 1) {
        printf("====== Compressing ======\n");
        printf("File count: %d\n", file_count);
        long original_size = calc_total_size(file_list, file_count);
        printf("Original size: %.2f MB\n", original_size / (1024.0 * 1024.0));
        clock_t start = clock();
        if (pack_multiple_files(output_path, file_list, file_count) != 0) {
            printf("Compression failed!\n");
            system("pause");
            return 1;
        }
        clock_t end = clock();
        FILE* f = fopen(output_path, "rb");
        fseek(f, 0, SEEK_END);
        long compressed_size = ftell(f);
        fclose(f);
        double ratio = (double)compressed_size / (double)original_size * 100.0;
        double time_used = (double)(end - start) / CLOCKS_PER_SEC;
        printf("\n====== Compression Complete ======\n");
        printf("Output file: %s\n", output_path);
        printf("Compressed size: %.2f MB\n", compressed_size / (1024.0 * 1024.0));
        printf("Ratio: %.1f%%\n", ratio);
        printf("Time: %.2f s\n", time_used);
        printf("Speed: %.2f MB/s\n",
               original_size / (1024.0 * 1024.0 * time_used));
    } else if (mode == 2) {
        printf("====== Decompressing ======\n");
        printf("Input file: %s\n", input_path);
        printf("Output dir: %s\n", output_dir);
        clock_t start = clock();
        if (unpack_multiple_files(input_path, output_dir) != 0) {
            printf("Decompression failed!\n");
            system("pause");
            return 1;
        }
        clock_t end = clock();
        double time_used = (double)(end - start) / CLOCKS_PER_SEC;
        printf("\n====== Decompression Complete ======\n");
        printf("Time: %.2f s\n", time_used);
    }
    system("pause");
    return 0;
}
